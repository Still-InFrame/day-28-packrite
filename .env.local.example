# Copy to .env.local and fill in from your Supabase project (Settings -> API).

# --- Public (safe for the browser) -----------------------------------------
# Use the Publishable key (sb_publishable_...), not the legacy anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Server-only secrets (NEVER sent to the client) ------------------------
# Master key for AES-256-GCM encryption of each user's Anthropic API key.
# Must be 32 random bytes, base64-encoded. Generate one with:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Shared secret the Supabase Database Webhook sends in the x-webhook-secret
# header so POST /api/catalog can trust it. Generate one with:
#   openssl rand -hex 24
CATALOG_WEBHOOK_SECRET=

# Service-role secret (Settings -> API -> service_role). OPTIONAL — only the
# production DB webhook uses it. Sharing and the admin dashboard work without it
# (they use SECURITY DEFINER functions, not this key).
SUPABASE_SERVICE_ROLE_KEY=

# Email allowed into the admin telemetry dashboard at /admin. Must also be added
# to the packrite_admins table (see supabase/schema.sql).
ADMIN_EMAIL=you@example.com

# The app's shared Anthropic key — powers the free tier (30 catalogs total/user).
# Optional: without it, users must add their own key. Users with their own key
# are unlimited and never use this one.
ANTHROPIC_API_KEY=

# --- Stripe subscriptions ($0.99/mo, $10/yr) — set when wiring up payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=    # price_… for the $0.99/mo recurring price
STRIPE_PRICE_YEARLY=     # price_… for the $10/yr recurring price
NEXT_PUBLIC_BASE_URL=https://packrite.100dayaichallenge.com
